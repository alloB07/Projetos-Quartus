`timescale 1 ps/ 1 ps

module dinossauroRawr (
	VGA_HS,
	CLOCK_50,
	KEY,
	VGA_VS,
	VGA_CLK,
	VGA_B,
	VGA_G,
	VGA_R);
output 	VGA_HS;
input 	CLOCK_50;
input 	[1:0] KEY;
output 	VGA_VS;
output 	VGA_CLK;
output 	[7:7] VGA_B;
output 	[7:7] VGA_G;
output 	[7:7] VGA_R;

